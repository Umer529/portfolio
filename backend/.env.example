# Copy to .env and fill in real values. NEVER commit real values.
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# Set to 1 when running behind a reverse proxy (Render/Railway/nginx).
# TRUST_PROXY=1

# Contact-form delivery via Resend (https://resend.com).
# RESEND_API_KEY=re_your_key_here
# CONTACT_TO=you@example.com
# CONTACT_FROM=Portfolio <onboarding@resend.dev>

# Supabase — service role key BYPASSES RLS. Never share or commit real values.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ADMIN_EMAIL=you@example.com
